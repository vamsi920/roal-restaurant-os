# Copy to `.env` in the project root (see README).
# Next.js loads `.env` automatically. `.env.local` overrides `.env` for duplicate keys.
# If you duplicate a key in `.env.local`, never leave it blank — an empty value overrides a valid `.env` entry.

# --- Required (app + dashboard) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Required for menu scanner (POST /api/scanner/extract) ---
GEMINI_API_KEY=your-gemini-api-key

# --- Recommended (KDS phone-order reads when RLS is strict; menu clear) ---
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Recommended: public site origin (canonicals, OG, billing redirects, Twilio webhook) ---
# Local dev: http://localhost:3000 — Production: https://your-domain.com (no trailing slash)
# On Vercel, VERCEL_URL is used when this is unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Optional: Gemini ---
# GEMINI_MODEL=gemini-2.5-flash

# --- ElevenLabs Conv AI (server-only; never NEXT_PUBLIC_) ---
# Required for voice agent connect + /api/integrations/elevenlabs/*
ELEVENLABS_API_KEY=
# Default agent when ?agent_id= is omitted
ELEVENLABS_AGENT_ID=
# Agent tools → Supabase Edge (set the SAME value in Supabase Edge Function secrets):
# Prefer signing secret (mints per-restaurant roal1.* tokens on Connect agent):
AGENT_TOOL_SIGNING_SECRET=
# Legacy global bearer (optional fallback; code uses SIGNING_SECRET first, then this):
# AGENT_TOOL_SECRET=
# Optional: require Authorization: Bearer <token> on POST .../sync-roal-tools
# ELEVENLABS_SYNC_TOKEN=
# Optional: protect GET/POST .../conversation-init (Twilio personalization webhook)
# ELEVENLABS_CONVERSATION_INIT_SECRET=
# IANA timezone for agent clock context (e.g. America/Chicago)
# RESTAURANT_AGENT_TIMEZONE=
# Set to 0 to skip creating/linking ROAL_order_taker_playbook KB doc
# ROAL_ORDER_KB=

# --- Playwright E2E smoke (local only; never commit real values) ---
# E2E_EMAIL=
# E2E_PASSWORD=
# E2E_RESTAURANT_ID=
# E2E_BASE_URL=http://localhost:3000
# E2E_SKIP_AUTH=1
# E2E_SKIP_SCANNER=1

# --- CLI scripts (optional) ---
# ROAL_SYNC_RESTAURANT_ID=
# ROAL_SYNC_RESTAURANT_NAME=
# SKIP_APP_URL_CHECK=1   # connect-elevenlabs-restaurant.ts only

# --- Planned: billing (Stripe) ---
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- Auth redirect (Supabase Dashboard → Auth → URL configuration) ---
# Site URL: http://localhost:3000  (or production)
# Redirect URLs: http://localhost:3000/auth/callback

# --- Supabase Edge (Dashboard → Edge Functions → Secrets; not in Next.js .env) ---
# SUPABASE_URL                 (auto-injected by Supabase)
# SUPABASE_SERVICE_ROLE_KEY    (auto-injected by Supabase)
# AGENT_TOOL_SIGNING_SECRET    (must match Next.js; preferred)
# AGENT_TOOL_SECRET            (optional legacy bearer fallback)
